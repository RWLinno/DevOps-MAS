
[Unit]
Description=DevOps-MAS API Service
After=network.target
Wants=network.target

[Service]
Type=exec
User=www-data
Group=www-data
WorkingDirectory=/opt/devops-mas
Environment=PYTHONPATH=/opt/devops-mas
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/devops-mas/venv/bin/uvicorn src.web.fastapi_app:app --host 0.0.0.0 --port 8000 --workers 4
ExecReload=/bin/kill -HUP $MAINPID
KillMode=mixed
TimeoutStopSec=5
PrivateTmp=true
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
